            </DataSet>
            <ReportControl name="SwitchRCB" confRev="1" datSet="SwitchStatus" rptID="E03_BCU/E03BCU/LLN0.SwitchRCB" buffered="false" intgPd="5000" bufTime="50">
              <TrgOps dchg="true" qchg="true" dupd="false" period="true" gi="true"/>
              <OptFields seqNum="true" timeStamp="true" dataSet="true" reasonCode="true" dataRef="true" entryID="false" configRef="true" bufOvfl="false"/>
              <RptEnabled max="5"/>
            </ReportControl>
            <GSEControl appID="E03BCU" name="gcbE03BCU" type="GOOSE" datSet="SwitchStatus" confRev="1"/>
            <DOI name="Mod">
              <DAI name="ctlModel">
                <Val>status-only</Val>
              </DAI>
            </DOI>
            <DOI name="NamPlt">
              <DAI name="vendor">
                <Val>ANTAM_SIM</Val>
              </DAI>
              <DAI name="swRev">
                <Val>1.0.0</Val>
              </DAI>
              <DAI name="d">
                <Val>Transformer-3 Bay Control Unit (C264)</Val>
              </DAI>
            </DOI>
          </LN0>
          <LN lnClass="LPHD" lnType="LPHD1" inst="1" prefix=""/>
          <LN lnClass="XCBR" lnType="XCBR1" inst="1" prefix="">
