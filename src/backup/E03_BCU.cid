    <AccessPoint name="AP1" desc="Primary Access Point">
      <Server timeout="30">
        <Authentication none="true"/>
        <LDevice inst="E03BCU" desc="Transformer-3 Bay Control Unit (C264)">
          <LN0 lnClass="LLN0" lnType="LLN0_BCU" inst="">
            <DataSet name="SwitchStatus">
              <FCDA ldInst="E03BCU" prefix="" lnClass="XCBR" fc="ST" lnInst="1" doName="Pos" daName="stVal"/>
